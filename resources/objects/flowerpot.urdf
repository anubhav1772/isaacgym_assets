<?xml version="1.0" ?>
<robot name="flowerpot">
  <link name="base">

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="flowerpot.obj" scale="0.5 0.5 0.5"/>
      </geometry>
      <material name="pot_color">
        <color rgba="0.6 0.3 0.1 1"/>
      </material>
    </visual>

    <collision>
    <geometry>
      <box size="0.2 0.2 0.3"/>
    </geometry>
  </collision>

  </link>
</robot>
