<?xml version="1.0" ?>
<robot name="guitar.urdf">
  <link name="baseLink">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
       <mass value="0.0"/>
       <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin rpy="0 1.57 0" xyz="4 4 0.2"/>
      <geometry>
        <mesh filename="guitar.obj" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wood">
        <color rgba="0.55 0.27 0.07 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="guitar.obj" scale="0.001 0.001 0.001"/>
        <!-- You could also specify the collision (for the guitar) with a "box" tag: -->
        <!-- <box size=".06 .06 .06"/> -->
      </geometry>
    </collision>
  </link>
</robot>
